# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Never commit real identity documents or borrower statements.
# Anything in public/ is served publicly — a real ID left here is downloadable from
# the internet the moment it deploys, and committing one puts it in git history for
# good. Test fixtures (MYIDFRONT.jpeg, M-Pesa statements) live here and stay local.
# Scoped to the public/ ROOT so genuine assets in images/ and lenders/ still ship.
public/*.pdf
public/*.jpeg
public/*.jpg
public/*.png
*.tmp.ts
