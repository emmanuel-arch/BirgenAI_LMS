# ── BirgenAI_LMS platform environment ─────────────────────────────────────────
# Per-LENDER secrets (Daraja, SMS, CRB, KYC, ServiceSuite conns) do NOT live
# here — they live encrypted per-org in OrgIntegration (the vault). This file
# holds platform-level config only.

# Dedicated Postgres (NOT the Hub's database)
DATABASE_URL="postgresql://user:pass@host:6543/birgenai_lms?pgbouncer=true"
# NOTE: on IPv4-only networks use the SESSION POOLER (aws-0-<region>.pooler.supabase.com:5432,
# username postgres.<ref>) as DIRECT_URL — the db.<ref>.supabase.co host is IPv6-only.
DIRECT_URL="postgresql://user:pass@host:5432/birgenai_lms"

# Auth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Vault master key (AES-256-GCM) for OrgIntegration.configEnc — 32 bytes hex.
# Rotate via re-encryption job; never log.
VAULT_MASTER_KEY=""

# Scoring engines (shared with the Hub deployment)
ORIGINATION_SCORER_URL="https://birgen-origination-engine-....run.app"   # v2 bespoke (Micromart)
ORIGINATION_POOLED_URL="https://birgen-pooled-engine-....run.app"        # v3 pooled (everyone else)
SCORER_V1_URL="https://birgen-ai-agent-....run.app/"                      # v1 behavioral monitor

# Platform email (staff/org onboarding; per-org SMTP is an Enterprise vault entry)
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BirgenAI LMS <no-reply@birgenai.com>"

# Default SMS provider for native orgs (per-org override in the vault)
AFRICASTALKING_USERNAME=""
AFRICASTALKING_API_KEY=""
AFRICASTALKING_SENDER_ID=""

# Cron/job auth (outcome-backfill runs daily 03:00 UTC via vercel.json)
CRON_SECRET=""

# ServiceSuite hook auth (bridged-mode server-to-server)
SERVICESUITE_HOOK_SECRET=""

# ── Bridged-mode ServiceSuite connections (Phase 1; moves into the per-org
#    encrypted vault in Phase 2). Same .NET-style strings ServiceSuite uses.
SERVICESUITE_CONN_MICROMART=""
SERVICESUITE_CONN_AXE=""
SERVICESUITE_CONN_BUYSIMU=""
# Optional per-org EntityId overrides:
# SERVICESUITE_ENTITYID_MICROMART=3002  SERVICESUITE_ENTITYID_AXE=3003

# Bridged posting (sp_InsertLoan into the BirgenAI workflow)
LMS_POSTING_ENABLED="false"          # true only after the lender's workflow exists
LMS_SERVICESUITE_CREATED_BY=""       # UserMaster.ID of the BirgenAI service account
LMS_SERVICESUITE_CHANNEL="7"         # ChannelUsed tag for portal-originated loans
SCORE_WRITEBACK_ENABLED="false"      # write BirgenAI score to Borrowers.CreditScore

# Behavioral (v1) scorer override; defaults to the deployed Cloud Run URL
# CREDIT_SCORER_URL=""

# Platform administration (org activation) — BirgenAI-side bearer secret
PLATFORM_ADMIN_SECRET=""
