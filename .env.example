# ── BirgenAI_LMS platform environment ─────────────────────────────────────────
# Per-LENDER secrets (Daraja, SMS, CRB, KYC, ServiceSuite conns) do NOT live
# here — they live encrypted per-org in OrgIntegration (the vault). This file
# holds platform-level config only.

# Dedicated Postgres (NOT the Hub's database)
DATABASE_URL="postgresql://user:pass@host:6543/birgenai_lms?pgbouncer=true"
# NOTE: on IPv4-only networks use the SESSION POOLER (aws-0-<region>.pooler.supabase.com:5432,
# username postgres.<ref>) as DIRECT_URL — the db.<ref>.supabase.co host is IPv6-only.
DIRECT_URL="postgresql://user:pass@host:5432/birgenai_lms"

# Auth
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"

# Vault master key (AES-256-GCM) for OrgIntegration.configEnc — 32 bytes hex.
# Rotate via re-encryption job; never log.
VAULT_MASTER_KEY=""

# Private object storage for KYC images (borrower ID photos, selfies, portraits).
# Supabase → Project Settings → API → service_role. SERVER ONLY: this key bypasses
# storage authorization entirely. Reads are served as short-lived signed URLs.
# Unset ⇒ storage runs in SIMULATION and no image is ever persisted.
# SUPABASE_URL is derived from DATABASE_URL's <role>.<projectref> when omitted.
SUPABASE_SERVICE_ROLE_KEY=""
# SUPABASE_URL="https://<projectref>.supabase.co"
# Run `npm run storage:init` once to create the private bucket.

# Scoring engines (shared with the Hub deployment)
ORIGINATION_SCORER_URL="https://birgen-origination-engine-....run.app"   # v2 bespoke (Micromart)
ORIGINATION_POOLED_URL="https://birgen-pooled-engine-....run.app"        # v3 pooled (everyone else)
SCORER_V1_URL="https://birgen-ai-agent-....run.app/"                      # v1 behavioral monitor

# Platform email (staff/org onboarding; per-org SMTP is an Enterprise vault entry)
SMTP_HOST="smtp.zoho.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="BirgenAI LMS <no-reply@birgenai.com>"

# Default SMS provider for native orgs (per-org override in the vault)
AFRICASTALKING_USERNAME=""
AFRICASTALKING_API_KEY=""
AFRICASTALKING_SENDER_ID=""

# Cron/job auth (outcome-backfill runs daily 03:00 UTC via vercel.json)
CRON_SECRET=""

# ServiceSuite hook auth (bridged-mode server-to-server)
SERVICESUITE_HOOK_SECRET=""

# ── Bridged-mode ServiceSuite connections (Phase 1; moves into the per-org
#    encrypted vault in Phase 2). Same .NET-style strings ServiceSuite uses.
SERVICESUITE_CONN_MICROMART=""
SERVICESUITE_CONN_AXE=""
SERVICESUITE_CONN_BUYSIMU=""
# Optional per-org EntityId overrides:
# SERVICESUITE_ENTITYID_MICROMART=3002  SERVICESUITE_ENTITYID_AXE=3003

# Bridged posting (sp_InsertLoan into the BirgenAI workflow)
LMS_POSTING_ENABLED="false"          # true only after the lender's workflow exists
LMS_SERVICESUITE_CREATED_BY=""       # UserMaster.ID of the BirgenAI service account
LMS_SERVICESUITE_CHANNEL="7"         # ChannelUsed tag for portal-originated loans
SCORE_WRITEBACK_ENABLED="false"      # write BirgenAI score to Borrowers.CreditScore

# Behavioral (v1) scorer override; defaults to the deployed Cloud Run URL
# CREDIT_SCORER_URL=""

# Platform administration (org activation, plan assignment) — BirgenAI-side bearer secret
PLATFORM_ADMIN_SECRET=""

# ── Centralised payments (the BirgenAI wallet) ────────────────────────────────
# PLATFORM RULE: every payment made TO BirgenAI — from birgenai.com and from every
# subdomain, this app included — settles through the Hub wallet. One Till, one
# ledger, one receipt. This app therefore has NO Daraja client for its own
# subscriptions; it deep-links to the Hub's /transact and reads the result back.
# (The per-org Daraja creds in the vault are a different thing entirely: they move
# the LENDER's money to and from their own borrowers.)
#
# LMS_BILLING_SECRET does double duty, and must hold the SAME value as the variable
# of the same name in the Hub deployment:
#   • it signs the short-lived checkout token that tells the Hub "this admin may buy
#     this package for this org" — the Hub cannot know that, our staff are in OUR db;
#   • it authenticates GET /api/lms/subscription when we read payment state back.
#
# Unset ⇒ checkout is unavailable and the sync is a no-op, so local subscription
# state stands and the demo org and local development keep working with no Hub.
HUB_BILLING_URL="https://birgenai.com"
LMS_BILLING_SECRET=""

# ── Maps & routing (Field Ops → Route Map) ────────────────────────────────────
# Google Maps Platform. TWO APIs must be enabled on the key's project:
#   • Maps JavaScript API   — the basemap itself
#   • Directions API        — the route, and duration_in_traffic (live Nairobi traffic)
#
# THIS KEY IS PUBLIC BY CONSTRUCTION. Maps JS authenticates from the browser, so the
# key ships in the client bundle — there is no server-side variant of a rendered map.
# Google's answer, and the ONLY answer, is an HTTP-referrer restriction:
#
#   Restrict to: lms.birgenai.com/*, *.birgenai.com/*, localhost:3000/*
#   Restrict to APIs: Maps JavaScript API + Directions API — nothing else.
#
# ⚠ CREATE A NEW KEY FOR THIS. Do NOT reuse GOOGLE_API_KEY / GOOGLE_CLOUD_API_KEY from
# the Hub or the agent projects: those can call Gemini, and a Gemini-capable key pasted
# here would be published in the bundle for anyone to bill to the project.
#
# Unset ⇒ the Route Map says so on screen and does not load. Nothing else is affected.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# ── Identity / KYC — THREE PROVIDERS, THREE JOBS (Smile ID is gone) ───────────
# The pipeline is: read the card → confirm the human exists → confirm it is them.
#
#   1. GOOGLE CLOUD VISION reads the ID front (TEXT_DETECTION).
#      SERVER-SIDE ONLY — never NEXT_PUBLIC. Restrict the key to the Cloud Vision API.
GOOGLE_CLOUD_API_KEY=""
#
#   2. IPRS (Spinmobile) confirms the ID number against the national registry, and
#      THE NAME ON THE CARD MUST BE THE NAME THE REGISTRY HOLDS FOR IT. That is the
#      fraud gate — see IPRS_* above.
#
#   3. AWS REKOGNITION compares the selfie to the portrait printed on the document.
#      Google Cloud Vision CANNOT do this — it has no face-comparison endpoint, by
#      policy — which is why identity deliberately spans two clouds.
#      IAM user needs only: rekognition:CompareFaces, rekognition:DetectFaces.
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION="eu-west-1"
#
# Each leg is simulation-first and INDEPENDENT: whichever credentials are present go
# live, the rest stay simulated, and the KYC screen names which is which per leg
# rather than showing one misleading "DEMO MODE" badge.

# ── M-Pesa callbacks ─────────────────────────────────────────────────────────
# ⚠ REQUIRED FOR STK TO WORK AT ALL. Daraja refuses a CallBackURL that is not a
# public HTTPS address — it answers "Bad Request - Invalid CallBackURL" and the
# customer's phone never rings. Without this, publicBase() falls back to
# NEXTAUTH_URL, which locally is http://localhost:3000, and every push fails.
PUBLIC_BASE_URL="https://lms.birgenai.com"
