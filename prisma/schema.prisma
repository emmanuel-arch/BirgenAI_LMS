// ─────────────────────────────────────────────────────────────────────────────
// BirgenAI_LMS — core schema (Phase 0 first cut).
//
// Multi-tenancy: every tenant-scoped row carries orgId, and Postgres RLS
// enforces it at the DB layer on top of app-level scoping — a cross-tenant leak
// must be architecturally impossible, not just unlikely.
//
// Three things must all hold, or RLS silently buys nothing:
//   1. `npm run db:rls`       — ENABLE + FORCE row security and the policies
//                               (re-run after any `db:push` that adds a table).
//   2. `npm run db:app-role`  — the app connects as `lms_app`, which has NO
//                               BYPASSRLS. Supabase's `postgres` role bypasses
//                               RLS entirely, FORCE included. DATABASE_URL must
//                               point at lms_app; DIRECT_URL stays the owner.
//   3. src/lib/prisma.ts      — stamps each transaction with the caller's tenant
//                               (`app.org_id`) so the policies have something to
//                               compare against. No stamp ⇒ no rows.
//
// `npm run db:rls:verify` runs a cross-tenant attack suite that proves all three.
//
// Bridged orgs (Micromart/Axe/BuySimu) keep their loan book in ServiceSuite;
// the adapter links records via serviceSuite* fields. Native orgs book here.
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

// Connection URLs live in prisma.config.ts (Prisma 7) — DATABASE_URL for the
// app (pooled), DIRECT_URL for migrations.
datasource db {
  provider = "postgresql"
}

// ── Platform / tenancy ────────────────────────────────────────────────────────

enum OrgMode {
  NATIVE // loan book lives in this DB
  BRIDGED // loan book lives in the lender's ServiceSuite; adapter reads/posts
}

enum OrgStatus {
  PENDING // self-onboarded, awaiting platform approval
  ACTIVE
  SUSPENDED
}

/// The four packages. Prices, features and quotas live in src/lib/billing/plans.ts;
/// the authoritative charge is always recomputed by the Hub's rate card at payment
/// time (all platform money moves through the Hub wallet).
///
/// NOTE the ladder ascends STARTER → ENTERPRISE → ADVANCED → PREMIUM, so
/// "Enterprise" is tier 2, not the top. Migrating from the old 3-tier enum
/// therefore PROMOTED the orgs previously marked ENTERPRISE to PREMIUM
/// (scripts/migrate-plans.ts), rather than silently demoting them.
enum OrgPlan {
  STARTER //  KES 10,000/mo
  ENTERPRISE //  KES 15,000/mo
  ADVANCED //  KES 20,000/mo
  PREMIUM //  KES 30,000/mo
}

enum SubscriptionStatus {
  TRIALING // full access to the chosen plan, nothing owed yet
  ACTIVE
  PAST_DUE // invoices unpaid — metered features stop, the loan book keeps running
  CANCELED
}

// Platform (founder-level) operators. NO orgId — they oversee every tenant, so
// this table is deliberately outside RLS (documented in rls.sql beside Org and
// RateLimit) and only ever touched under runAsPlatform() by /platform surfaces.
model PlatformAdmin {
  id           String    @id @default(uuid())
  email        String    @unique
  name         String
  passwordHash String
  status       String    @default("ACTIVE") // ACTIVE | DISABLED
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
}

model Org {
  id        String    @id @default(uuid())
  slug      String    @unique // subdomain: <slug>.birgenai.com
  name      String
  mode      OrgMode   @default(NATIVE)
  status    OrgStatus @default(PENDING)
  plan      OrgPlan   @default(STARTER)
  country   String    @default("KE")
  currency  String    @default("KES")
  timezone  String    @default("Africa/Nairobi")
  // Branding (white-label): accent drives --brand, assets in storage.
  accent     String  @default("#F97316")
  accentSoft String  @default("rgba(249,115,22,0.12)")
  // Optional second gradient stop (logo-derived). Null ⇒ derived from accent at render.
  accent2    String?
  tagline    String?
  blurb      String?
  logoUrl    String?
  heroUrl    String?
  // First-run setup checklist ({ dismissed?: boolean, activationRequestedAt?: string })
  onboardingState Json?
  // Field-ops control: a borrower's business/home location SNAPSHOT must be on file
  // before money is released to them (you should know where your borrower's business
  // is before you lend against it, and a customer with no pin never appears on a
  // field officer's route). Defaults ON; a purely-digital lender can turn it off.
  requireGeoForDisbursement Boolean @default(true)
  // Bridged-mode link
  serviceSuiteEntityId Int?
  // Demo orgs power the guided showcase (test accounts, seeded lifecycle).
  isDemo    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription  OrgSubscription?
  integrations  OrgIntegration[]
  branches      Branch[]
  roles         Role[]
  staff         StaffUser[]
  borrowers     Borrower[]
  products      Product[]
  workflows     Workflow[]
  applications  LoanApplication[]
  offers        LoanOffer[]
  guarantors    Guarantor[]
  collateral    Collateral[]
  documents     Document[]
  invoices      Invoice[]
  tuning        TuningProfile?
  loans         Loan[]
  usageEvents   UsageEvent[]
  fieldVisits   FieldVisit[]
  smsWallet     SmsWallet?
  smsTopUps     SmsTopUp[]
  reconExceptions ReconciliationException[]
  promises      PromiseToPay[]
  collectionCalls CollectionCall[]
  tickets       CollectionTicket[]
  smsCampaigns  SmsCampaign[]
  emails        EmailMessage[]
  metricDefs    MetricDefinition[]
  ririQueries   RiriQueryLog[]
  complianceRequests ComplianceRequest[]
  charges       Charge[]
  graduations   GraduationEvent[]
  savingsAccounts     SavingsAccount[]
  savingsTransactions SavingsTransaction[]
  ririMemories        RiriMemory[]
}

enum IntegrationKind {
  MPESA_STK // Daraja STK push (collections)
  MPESA_B2C // Daraja B2C (disbursement) — NATIVE orgs only
  MPESA_C2B // paybill callback registration
  SMS // provider + apiKey + senderId
  SMTP // per-org from-address (Enterprise)
  CRB // TransUnion / Metropol / Creditinfo (lender's subscription)
  KYC // Smile ID keys
  SERVICESUITE // bridged: .NET conn string + entityId + posting config
  WEBHOOK
}

enum IntegrationStatus {
  UNCONFIGURED
  CONFIGURED // saved, not verified
  TESTED // test call succeeded
  LIVE
  DISABLED
}

/// Per-org integration config. `configEnc` is an AES-256-GCM-encrypted JSON
/// blob (master key in env: VAULT_MASTER_KEY) — secrets never live in env vars
/// per tenant and never leave the server.
model OrgIntegration {
  id        String            @id @default(uuid())
  orgId     String
  kind      IntegrationKind
  status    IntegrationStatus @default(UNCONFIGURED)
  configEnc String // base64(iv || ciphertext || tag)
  lastTestAt DateTime?
  lastError  String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])

  @@unique([orgId, kind])
  @@index([orgId])
}

model Branch {
  id                String  @id @default(uuid())
  orgId             String
  name              String
  /// Null == the ROOT of the tree: the lender's head office. Exactly one per org.
  parentId          String?
  levelName         String  @default("Branch") // org-defined hierarchy level
  /// Short code an officer would actually say out loud ("NRB-CBD"). Optional.
  code              String?
  disbursementLimit Decimal? @db.Decimal(18, 2)
  lat               Float?
  lng               Float?
  radiusMeters      Int?
  active            Boolean @default(true)
  createdAt         DateTime @default(now())

  org      Org      @relation(fields: [orgId], references: [id])
  parent   Branch?  @relation("BranchTree", fields: [parentId], references: [id])
  children Branch[] @relation("BranchTree")
  staff    StaffUser[]

  @@index([orgId])
}

// ── Staff, roles, audit ───────────────────────────────────────────────────────

/// HOW MUCH OF THE BOOK A ROLE MAY SEE — orthogonal to rights.
///
/// Rights answer "may you open the borrower list at all"; this answers "WHOSE
/// borrowers are on it". They are genuinely different questions: a Loan Officer and
/// a Branch Manager have almost identical rights and must not see the same rows.
/// Without this, `borrowers.view` meant *every* borrower in the lender, so a
/// one-branch officer could read the whole book.
enum DataScope {
  /// Only what this person originated. An officer's own portfolio.
  OWN
  /// Everything booked at the staff member's own branch.
  BRANCH
  /// Their branch and every branch beneath it — how a regional manager sees a region.
  BRANCH_TREE
  /// The whole lender. Head office, admins, auditors.
  ORG
}

model Role {
  id        String   @id @default(uuid())
  orgId     String
  title     String
  rights    Json     @default("[]") // module-right keys
  menu      Json     @default("[]") // visible menu keys

  /// Defaults to ORG so that adding this column changes NOTHING for a role that
  /// existed before it: every role kept exactly the visibility it already had, and a
  /// lender narrows deliberately rather than discovering their officers went blind
  /// after a deploy.
  dataScope DataScope @default(ORG)

  createdAt DateTime @default(now())

  org   Org         @relation(fields: [orgId], references: [id])
  staff StaffUser[]

  @@unique([orgId, title])
}

enum StaffStatus {
  INVITED
  ACTIVE
  LOCKED
  DISABLED
}

model StaffUser {
  id           String      @id @default(uuid())
  orgId        String
  email        String
  phone        String?
  firstName    String
  otherName    String?
  passwordHash String?
  roleId       String?
  branchId     String?
  // Approval tiers (ServiceSuite Initiator/Authorizor/Validator parity)
  isInitiator  Boolean     @default(false)
  isAuthorizer Boolean     @default(false)
  isValidator  Boolean     @default(false)
  // Field ops — relationship officers/agents get geolocated for nearest-agent
  // routing. lat/lng is their last known base (branch or live check-in).
  isFieldAgent    Boolean   @default(false)
  lat             Float?
  lng             Float?
  lastLocationAt  DateTime?
  status       StaffStatus @default(INVITED)
  lastLoginAt  DateTime?
  otpSecret    String?
  avatarSeed   String? // deterministic avatar for demo/console polish
  title        String? // display job title (e.g. "Relationship Officer")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  org    Org     @relation(fields: [orgId], references: [id])
  role   Role?   @relation(fields: [roleId], references: [id])
  branch Branch? @relation(fields: [branchId], references: [id])
  visitsAssigned FieldVisit[] @relation("VisitAgent")

  @@unique([orgId, email])
  @@index([orgId])
  @@index([orgId, isFieldAgent])
}

enum FieldVisitStatus {
  QUEUED // created, awaiting allocation
  ALLOCATED // nearest agent assigned
  EN_ROUTE
  ARRIVED
  VERIFIED // agent confirmed the physical reality (shop/home exists)
  FAILED // could not verify
  CANCELLED
}

enum FieldVisitKind {
  BUSINESS_VERIFICATION // SME: confirm the shop/stock exists
  HOME_VERIFICATION
  COLLECTION_VISIT
  KYC_ASSIST
}

/// A geolocated field task. The "RO becomes an API": software schedules the one
/// thing it can't confirm remotely, and the nearest available agent is allocated
/// automatically (Haversine) and submits the verification from the field.
model FieldVisit {
  id            String           @id @default(uuid())
  orgId         String
  borrowerId    String?
  applicationId String?
  kind          FieldVisitKind   @default(BUSINESS_VERIFICATION)
  status        FieldVisitStatus @default(QUEUED)
  label         String
  address       String?
  lat           Float
  lng           Float
  agentId       String?
  allocatedAt   DateTime?
  distanceKm    Float? // agent→target at allocation time
  visitedAt     DateTime?
  outcome       String?
  notes         String?
  photoKey      String?
  createdBy     String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  org      Org        @relation(fields: [orgId], references: [id])
  borrower Borrower?  @relation(fields: [borrowerId], references: [id])
  agent    StaffUser? @relation("VisitAgent", fields: [agentId], references: [id])

  @@index([orgId, status])
  @@index([agentId, status])
}

/// A borrower KYC verification session — the elite onboarding funnel's spine.
/// Each step writes a KycCheck; this row rolls them up into one live status the
/// wizard and officers watch. `provider` = "simulation" until real creds are in
/// the vault (Smile ID), then "smile-id".
model KycSession {
  id             String    @id @default(uuid())
  orgId          String
  borrowerId     String?
  phone          String
  nationalId     String?
  provider       String    @default("simulation")
  // step results (0..100 confidence where applicable)
  idQualityScore    Int?
  idOcrName         String?
  idOcrNumber       String?
  idOcrDob          String?
  livenessScore     Int?
  livenessPassed    Boolean?
  faceMatchScore    Int?
  iprsMatched       Boolean?
  iprsName          String?
  // Private-bucket object keys (src/lib/storage/provider.ts), never public URLs.
  // Read only through a short-lived signed URL. A `sim/` prefix means storage was
  // in simulation and no bytes were ever written.
  idFrontKey        String?
  idBackKey         String?
  selfieKey         String?
  portraitKey       String?
  // rollup
  status         String    @default("IN_PROGRESS") // IN_PROGRESS | PENDING_REVIEW | VERIFIED | FAILED
  riskFlags      Json?
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([orgId, phone])
}

/// One-time codes, for two different subjects:
///   staffId — a staff member authorising a sensitive action (final approvals)
///   phone   — a borrower proving possession of their number before the funnel
/// Exactly one of the two is set. Only the bcrypt hash is stored, codes expire
/// fast, and a challenge is burned after MAX_ATTEMPTS wrong guesses — otherwise
/// a 6-digit code is a 1,000,000-guess walk against a live SMS.
model OtpChallenge {
  id        String    @id @default(uuid())
  orgId     String
  staffId   String?
  phone     String? // digits-only msisdn (2547XXXXXXXX)
  purpose   String // e.g. "application:<id>:finalize" | "borrower:verify"
  codeHash  String
  attempts  Int       @default(0)
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([orgId, staffId, purpose])
  @@index([orgId, phone, purpose])
}

model AuditLog {
  id        String   @id @default(uuid())
  orgId     String?
  actorId   String? // StaffUser.id or Borrower.id or "system"
  actorType String   @default("staff") // staff | borrower | system | platform
  action    String // e.g. "loan.approve", "disbursement.check"
  entity    String?
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([orgId, createdAt])
  @@index([entity, entityId])
}

// ── Borrowers & KYC ───────────────────────────────────────────────────────────

enum KycStatus {
  NONE
  IN_PROGRESS
  PENDING_REVIEW // face-match/liveness in the human-review band
  VERIFIED
  FAILED
}

model Borrower {
  id         String    @id @default(uuid())
  orgId      String
  phone      String // digits-only 2547XXXXXXXX
  nationalId String?
  firstName  String?
  otherName  String?
  email      String?
  dob        DateTime?
  gender     String?
  /// "en" | "sw" — the language they chose on the portal. Every borrower-facing
  /// SMS (reminders, receipts, signing codes) follows it (src/lib/sms/send.ts).
  language   String    @default("en")
  /// { name, relationship, phone } — who to call when the borrower cannot be
  /// reached. Captured from Customer-360; a collections tool, never a guarantor.
  nextOfKin  Json?
  // KYC artifacts (private storage keys, not public URLs)
  portraitKey     String? // white-background canonical portrait
  selfieKey       String?
  idFrontKey      String?
  idBackKey       String?
  faceMatchScore  Float?
  livenessPassed  Boolean?
  iprsVerified    Boolean?
  kycStatus       KycStatus @default(NONE)
  kycVerifiedAt   DateTime?
  // One-time consented location SNAPSHOTS (captured at onboarding/application with
  // the customer's explicit consent — never tracked afterwards). lat/lng is the
  // primary pin (locationType says which place it is); a second pin lives in
  // homeLat/homeLng when both business and home were captured.
  lat             Float?
  lng             Float?
  locationType    String? // business | home
  locationAddress String?
  homeLat         Float?
  homeLng         Float?
  homeAddress     String?
  geoConsentAt    DateTime? // when the customer consented to the location snapshot
  // Risk & limits
  creditScore       Int?
  /// One of the four bands (src/lib/risk/bands.ts): PRIME | STRONG | WATCH | HIGH.
  /// Every engine — the thin-file cruncher, the behavioural scorer, early warning —
  /// speaks this one vocabulary, so an officer never has to translate between scales.
  riskBand          String?
  /// 0–100, from their last two CLEARED loans: half "did they pay it all", half "did
  /// they pay it on the day". This is the number graduation is decided on, and it is
  /// written for every customer who has ever repaid — including the bad ones.
  behaviouralScore  Float?
  lastScoredAt      DateTime?
  lastGraduationAt  DateTime?
  loanLimit         Decimal? @db.Decimal(18, 2)
  previousLoanLimit Decimal? @db.Decimal(18, 2)
  graduationCount   Int      @default(0)
  // Bridged link + suite SSO federation
  serviceSuiteBorrowerId Int?
  hubUserId              String? // birgenai.com account id (federated login)
  deviceFingerprint      String?

  /// WHO owns this customer and WHERE they belong. Both are stamped at registration
  /// and are what every data-scope decision reads (src/lib/rbac/scope.ts).
  /// A borrower who arrived through the public portal has no officer; they are stamped
  /// to the head office, where a manager can see them and assign them out — a null
  /// branch would belong to no one and quietly accumulate leads nobody was told about.
  createdById String? // StaffUser.id of the officer who registered them
  branchId    String?

  /// Set when this person exercised their right to erasure and a financial record
  /// (AML floor, 7 years) made a hard delete unlawful. The row survives; the person
  /// does not — name, phone, ID, email, face and location are gone, and `phone` holds
  /// an unusable tombstone so the (orgId, phone) uniqueness still means something.
  /// Every screen must read this before it renders a "borrower".
  erasedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org          Org               @relation(fields: [orgId], references: [id])
  consents     Consent[]
  kycChecks    KycCheck[]
  applications LoanApplication[]
  offers       LoanOffer[]
  guarantors   Guarantor[]
  collateral   Collateral[]
  documents    Document[]
  loans        Loan[]
  fieldVisits  FieldVisit[]
  savings      SavingsAccount?

  @@unique([orgId, phone])
  @@index([orgId, nationalId])
}

model Consent {
  id         String   @id @default(uuid())
  orgId      String
  borrowerId String
  version    String // e.g. "2026-07-08"
  grants     Json // { mpesaAnalysis, automatedScoring, crbCheck, iprs, modelImprovement, crossBorder, geoTagging }
  ip         String?
  createdAt  DateTime @default(now())

  borrower Borrower @relation(fields: [borrowerId], references: [id])

  @@index([orgId, borrowerId])
}

enum KycCheckKind {
  ID_QUALITY
  ID_OCR
  LIVENESS
  FACE_MATCH
  PORTRAIT_STANDARDIZE
  IPRS
  CRB
  DEVICE
  /// A human override of a failed face-match/liveness, recorded with the
  /// voucher's staffId and mandatory note. Can never override IPRS.
  VOUCH
}

model KycCheck {
  id         String       @id @default(uuid())
  orgId      String
  // Optional: KYC checks run DURING onboarding, before a Borrower row exists;
  // the KycSession links them and they attach to the borrower once created.
  borrowerId String?
  sessionId  String?
  kind       KycCheckKind
  passed     Boolean?
  score      Float?
  provider   String? // e.g. "smile-id", "internal"
  payload    Json?
  createdAt  DateTime     @default(now())

  borrower Borrower? @relation(fields: [borrowerId], references: [id])

  @@index([orgId, borrowerId, kind])
  @@index([sessionId])
}

// ── Products & workflows ──────────────────────────────────────────────────────

enum DisbursementMode {
  B2C_MPESA // native: Daraja B2C from the org's vault credentials
  MANUAL // record-only: staff disburse outside, confirm ref
  TO_THIRD_PARTY // e.g. school-fees: paid to the institution's paybill
  LENDER_SIDE // bridged: the lender's existing ServiceSuite/ops process
}

model Product {
  id            String  @id @default(uuid())
  orgId         String
  name          String
  description   String?
  minPrincipal  Decimal  @db.Decimal(18, 2)
  maxPrincipal  Decimal  @db.Decimal(18, 2)
  interestRate  Decimal  @db.Decimal(9, 4)
  interestMethod String  @default("flat") // flat | reducing (how the balance interest is computed)
  /// The pricing basis behind the rate — mirrors ServiceSuite's Interest Type, kept
  /// distinct from the flat/reducing METHOD above. fixed = rate never moves for the
  /// life of the loan; variable = repriced against a reference on rollover/reschedule.
  interestType   String  @default("fixed") // fixed | variable
  /// The repayment shape — ServiceSuite's Principal (Product) Type. standard amortises
  /// principal+interest across every installment; interest_first services interest until
  /// the final installment; balloon carries most principal to the last.
  principalType  String  @default("standard") // standard | interest_first | balloon
  interestPeriodUnit String @default("month")
  repaymentPeriod    Int
  repaymentPeriodUnit String @default("week")
  gracePeriodDays    Int     @default(0)
  penaltyRate        Decimal? @db.Decimal(9, 4)
  /// A settlement before `earlySettlementDays` from disbursement is rebated at
  /// `earlySettlementRate` (% of outstanding interest waived). Off by default.
  earlySettlementEnabled Boolean  @default(false)
  earlySettlementDays    Int?
  earlySettlementRate    Decimal? @db.Decimal(9, 4)
  /// The waterfall a payment is applied in, most-senior first. ServiceSuite's
  /// Repayment Order. Tokens: fees | penalty | interest | principal.
  repaymentOrder     String  @default("penalty,interest,principal,fees")
  /// The smallest amount this product will ever book, even if the limit engine
  /// derives less — below it, there is no loan (ServiceSuite Minimum Loan Limit).
  minLoanLimit       Decimal? @db.Decimal(18, 2)
  minCreditScore     Int?
  guarantorRequired  Boolean @default(false)
  /// May a person who is standing as a guarantor on a live loan also take one of
  /// their own on this product? Off = a guarantor's exposure is frozen.
  guarantorReborrow  Boolean @default(false)
  securityRequired   Boolean @default(false)
  /// Verified collateral must cover this percentage of the principal before a loan
  /// on this product may book. Only meaningful when securityRequired.
  securityCoverPct   Int     @default(100)
  disbursementMode   DisbursementMode @default(B2C_MPESA)
  newWorkflowId      String?
  repeatWorkflowId   String?
  isActive           Boolean @default(true)
  // Bridged link
  serviceSuiteProductId Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org          Org               @relation(fields: [orgId], references: [id])
  applications LoanApplication[]
  loans        Loan[]

  @@index([orgId, isActive])
}

model Workflow {
  id          String  @id @default(uuid())
  orgId       String
  title       String
  description String?
  createdAt   DateTime @default(now())

  org    Org             @relation(fields: [orgId], references: [id])
  stages WorkflowStage[]

  @@unique([orgId, title])
}

model WorkflowStage {
  id          String  @id @default(uuid())
  workflowId  String
  title       String
  parentId    String? // stage tree (ServiceSuite ParentStage parity)
  order       Int     @default(1)
  accessTier  Int     @default(1) // 1 initiator · 2 authorizer · 3 validator
  roleIds     Json    @default("[]")
  canFinalize Boolean @default(false) // finalize → disbursement queue
  canUpdate   Boolean @default(false)
  otpRequired Boolean @default(true)
  maxAmount   Decimal? @db.Decimal(18, 2) // finalize amount cap

  workflow Workflow        @relation(fields: [workflowId], references: [id])
  parent   WorkflowStage?  @relation("StageTree", fields: [parentId], references: [id])
  children WorkflowStage[] @relation("StageTree")
}

// ── Applications, loans, schedules ───────────────────────────────────────────

enum ApplicationStatus {
  SUBMITTED
  AI_PRESCREEN
  OFFICER_REVIEW
  APPROVED
  DISBURSED
  REFERRED
  DECLINED
  WITHDRAWN
}

/// One row per application = one training row (features X now, outcome y
/// backfilled). Mirrors the Hub's LmsApplication contract.
model LoanApplication {
  id         String            @id @default(uuid())
  orgId      String
  borrowerId String
  productId  String?
  // Bridged-mode product reference (ServiceSuite Products.ID) + display name —
  // native orgs use productId instead.
  productRef  String?
  productName String?
  // Application-time identity snapshot (the training row is self-contained).
  phone        String?
  nationalId   String?
  borrowerName String?
  hubUserId    String?
  graduated      Boolean @default(false)
  priorLoanCount Int     @default(0)
  serviceSuiteBorrowerId Int?
  amountRequested Decimal      @db.Decimal(18, 2)
  status     ApplicationStatus @default(SUBMITTED)
  stageTitle String?
  currentStageId String?
  // Scoring (server-side recompute only)
  score            Int?
  pd               Decimal? @db.Decimal(6, 5)
  scoreModelVersion String?
  fusionEngine     String? // thin-file | origination | fused
  decision         String? // APPROVE | REFER | DECLINE
  reasonCodes      Json?
  featuresSnapshot Json? // M-Pesa cashflow features (X)
  /// The ceiling the limit engine derived at apply time (lib/lending/limits.ts):
  /// cashflow capacity × risk × the progressive-exposure ladder, inside product
  /// bounds. The amount requested was validated against it server-side.
  approvedLimit    Decimal? @db.Decimal(18, 2)
  consentId        String?
  consent          Json? // application-time consent snapshot (versioned, IP-stamped)
  consentVersion   String?
  // Fraud signal: a hash of the applying device's stable traits. The same
  // device applying as many different people is the classic ring pattern.
  deviceFingerprint String?

  /// Whose application this is, and where it was taken. Stamped from the borrower at
  /// creation so the queue can be scoped without a join back through the borrower.
  officerId String? // StaffUser.id
  branchId  String?
  // Pay-to-institution products (§7 diversion control): the money goes to the
  // school's paybill, never the borrower's phone. Captured at application.
  payeeName    String?
  payeePaybill String?
  payeeAccount String? // e.g. the student's admission number
  // Consented one-time geo
  lat             Float?
  lng             Float?
  locationType    String?
  locationAddress String?
  // Bridged posting
  postedToServiceSuite Boolean @default(false)
  serviceSuiteLoanId   String?
  postError            String?
  // Outcome label (y) — backfilled by the daily cron from the loan book
  outcome           String    @default("PENDING") // PENDING | REPAID | DEFAULTED
  outcomeObservedAt DateTime?
  daysToDefault     Int?
  decidedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Org        @relation(fields: [orgId], references: [id])
  borrower Borrower   @relation(fields: [borrowerId], references: [id])
  product  Product?   @relation(fields: [productId], references: [id])
  loan       Loan?
  offer      LoanOffer?
  guarantors Guarantor[]

  @@index([orgId, status])
  @@index([orgId, borrowerId])
  @@index([orgId, outcome])
}

/// A lender's own scoring policy for Portfolio Early Warning.
///
/// Advisory only: these weights decide who an officer is told to call first. They
/// cannot change a schedule, a balance, or a credit decision already made. Absent a
/// row, the engine runs on DEFAULT_WEIGHTS and behaves exactly as it always has.
///
/// Every save is validated, clamped and written to the audit log — a scoring policy
/// a lender cannot explain is a scoring policy a regulator will not accept.
model TuningProfile {
  id     String @id @default(uuid())
  orgId  String @unique
  /// Points added per risk factor. See lib/intelligence/tuning.ts → Weights.
  weights    Json
  /// Band cut-offs and the thresholds the weights key off. → Thresholds.
  thresholds Json
  /// Bumped on every save, so a score can be traced to the policy that produced it.
  version    Int    @default(1)
  note       String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])
}

enum DocumentKind {
  FEE_STRUCTURE
  INVOICE
  PERMIT
  BANK_STATEMENT
  NATIONAL_ID
  OTHER
}

enum DocumentStatus {
  PARSED // fields read, confidence above the review threshold
  NEEDS_REVIEW // read, but an expected field is missing — a human checks it
  UNPARSED // stored, unreadable without OCR (a photo, or a scanned PDF)
  FAILED // the file could not be opened at all
}

/// A borrower's paperwork: fee structures, invoices, permits, statements, IDs.
///
/// The bytes live in a private bucket; only the extracted fields live here. Raw
/// document text is deliberately NOT stored — it is PII, and we have no use for it
/// once the fields are out. `confidence` is the share of a kind's needed fields we
/// found, not a probability, and anything below the review threshold is flagged
/// rather than trusted.
model Document {
  id            String  @id @default(uuid())
  orgId         String
  borrowerId    String?
  applicationId String?
  loanId        String?

  kind        DocumentKind
  filename    String
  contentType String
  bytes       Int
  pages       Int?
  /// Object key in the private docs bucket. `sim/…` ⇒ storage is simulated.
  storageKey  String

  status     DocumentStatus
  confidence Float          @default(0)
  /// Structured output. Shape depends on `kind`; see lib/documents/extract.ts.
  fields     Json?
  /// What is missing, or why it could not be read — in words an officer can act on.
  note       String?
  parserMode String         @default("simulation")

  uploadedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org      Org       @relation(fields: [orgId], references: [id])
  borrower Borrower? @relation(fields: [borrowerId], references: [id])

  @@index([orgId, createdAt])
  @@index([orgId, borrowerId])
  @@index([orgId, status])
}

enum GuarantorStatus {
  INVITED // asked, not yet answered
  CONSENTED // stood behind a specific agreement, with a code sent to their own phone
  DECLINED
  EXPIRED
}

/// Someone who stands behind a borrower's loan.
///
/// A guarantor consents to ONE agreement, identified by `offerTermsHash`. If the
/// borrower's offer is re-issued on different terms, that consent is stale and the
/// loan will not book — a person who agreed to guarantee KES 10,000 has not agreed
/// to guarantee KES 50,000, and no amount of convenience justifies pretending
/// otherwise. Consent is proved by a one-time code sent to the guarantor's own
/// phone, never to the borrower's.
model Guarantor {
  id            String @id @default(uuid())
  orgId         String
  applicationId String
  /// The applicant they are guaranteeing (denormalised for the officer's queries).
  borrowerId    String

  fullName     String
  phone        String // digits-only msisdn
  nationalId   String?
  relationship String? // "brother", "business partner", …

  status GuarantorStatus @default(INVITED)
  /// The exact agreement stood behind. Null until an offer exists to bind to.
  offerTermsHash String?
  /// Defaults to the whole repayable amount. A partial guarantee is a later feature.
  amountGuaranteed Decimal? @db.Decimal(18, 2)

  invitedAt  DateTime  @default(now())
  invitedBy  String?
  remindedAt DateTime?
  consentedAt DateTime?
  declinedAt  DateTime?
  /// Evidence of the signature: where from, on what, and which challenge proved possession.
  consentIp        String?
  consentUserAgent String?
  otpChallengeId   String?
  expiresAt        DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org         Org             @relation(fields: [orgId], references: [id])
  application LoanApplication @relation(fields: [applicationId], references: [id])
  borrower    Borrower        @relation(fields: [borrowerId], references: [id])

  @@index([orgId, applicationId])
  @@index([orgId, phone])
  @@index([orgId, status])
}

enum CollateralKind {
  VEHICLE
  LAND
  EQUIPMENT
  STOCK // trading inventory
  CHATTEL // household or business goods
  OTHER
}

enum CollateralStatus {
  REGISTERED // the borrower says they own it
  VERIFIED // a staff member has seen it, and says so under their own name
  REJECTED
  RELEASED // the loan cleared; the security is discharged
  SEIZED
}

/// Security pledged against a loan.
///
/// Only VERIFIED collateral counts toward a product's security requirement. A
/// borrower's own claim about what they own is a starting point, not a valuation —
/// somebody has to look at the lorry.
model Collateral {
  id            String  @id @default(uuid())
  orgId         String
  applicationId String?
  loanId        String?
  borrowerId    String

  kind             CollateralKind
  description      String
  estimatedValueKes Decimal       @db.Decimal(18, 2)
  registrationRef  String? // logbook number, title deed, serial
  /// Proof — a logbook scan, a title deed — in the private documents bucket.
  documentId       String?

  status         CollateralStatus @default(REGISTERED)
  verifiedBy     String?
  verifiedAt     DateTime?
  rejectedReason String?
  releasedAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org      Org      @relation(fields: [orgId], references: [id])
  borrower Borrower @relation(fields: [borrowerId], references: [id])

  @@index([orgId, applicationId])
  @@index([orgId, loanId])
  @@index([orgId, status])
}

enum OfferStatus {
  OFFERED
  ACCEPTED
  DECLINED
  EXPIRED
}

enum OfferChannel {
  PORTAL // the borrower signed it themselves, with an SMS one-time code
  BRANCH // staff recorded a signature taken in person
}

/// The credit agreement, as presented to the borrower and as accepted by them.
///
/// A native loan may not be booked without an ACCEPTED offer. This row is the legal
/// artifact: the exact terms shown, the exact schedule read, a hash over those terms,
/// and how the acceptance was obtained. When a lender is asked "what did this person
/// agree to, and how do you know?", the answer should be one row.
///
/// Terms are stored, never re-derived: a product's rate may change after an offer
/// goes out, and the borrower agreed to the number they saw. Booking regenerates the
/// schedule from these stored terms with the same `buildSchedule` that produced them
/// and refuses to book if the totals disagree.
model LoanOffer {
  id            String @id @default(uuid())
  orgId         String
  applicationId String @unique
  borrowerId    String
  productId     String

  principal      Decimal @db.Decimal(18, 2)
  interestRate   Decimal @db.Decimal(9, 4)
  interestMethod String // flat | reducing
  termCount      Int
  termUnit       String
  graceDays      Int     @default(0)
  totalInterest  Decimal @db.Decimal(18, 2)
  totalRepayable Decimal @db.Decimal(18, 2)

  borrowDate        DateTime
  firstDueDate      DateTime
  expectedClearDate DateTime
  /// The installment rows the borrower actually read.
  schedule          Json
  /// sha256 over the canonical terms — what was signed.
  termsHash         String

  status    OfferStatus @default(OFFERED)
  expiresAt DateTime

  acceptedAt DateTime?
  declinedAt DateTime?
  channel    OfferChannel?
  /// Evidence of the e-signature: where from, on what, and which challenge proved possession.
  acceptedIp        String?
  acceptedUserAgent String?
  otpChallengeId    String?
  /// Staff who recorded an in-person acceptance (BRANCH channel only).
  recordedBy        String?
  branchNote        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org         Org             @relation(fields: [orgId], references: [id])
  application LoanApplication @relation(fields: [applicationId], references: [id])
  borrower    Borrower        @relation(fields: [borrowerId], references: [id])

  @@index([orgId, status])
  @@index([orgId, borrowerId])
  @@index([expiresAt])
}

enum LoanStatus {
  PENDING_DISBURSEMENT
  ACTIVE
  CLEARED
  WRITTEN_OFF
  RESTRUCTURED
}

model Loan {
  id            String     @id @default(uuid())
  orgId         String
  borrowerId    String
  applicationId String?    @unique
  productId     String
  principal     Decimal    @db.Decimal(18, 2)
  interest      Decimal    @db.Decimal(18, 2)
  loanAmount    Decimal    @db.Decimal(18, 2) // principal + interest (+fees)
  balance       Decimal    @db.Decimal(18, 2)
  status        LoanStatus @default(PENDING_DISBURSEMENT)
  borrowDate    DateTime   @default(now())
  expectedClearDate DateTime?
  disbursedAt   DateTime?
  clearedAt     DateTime?
  createdBy     String? // StaffUser.id — the officer whose book this loan is on
  /// The branch that owns this loan. Frozen at booking: a loan does not move branch
  /// because an officer transferred.
  branchId      String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  org          Org              @relation(fields: [orgId], references: [id])
  borrower     Borrower         @relation(fields: [borrowerId], references: [id])
  product      Product          @relation(fields: [productId], references: [id])
  application  LoanApplication? @relation(fields: [applicationId], references: [id])
  installments Installment[]
  disbursement Disbursement?

  @@index([orgId, status])
  @@index([orgId, borrowerId])
}

enum InstallmentStatus {
  UPCOMING
  DUE
  PAID
  PARTIAL
  OVERDUE
}

model Installment {
  id           String            @id @default(uuid())
  orgId        String
  loanId       String
  seq          Int
  dueDate      DateTime
  amountDue    Decimal           @db.Decimal(18, 2)
  principalDue Decimal           @db.Decimal(18, 2)
  interestDue  Decimal           @db.Decimal(18, 2)
  amountPaid   Decimal           @default(0) @db.Decimal(18, 2)
  penalty      Decimal           @default(0) @db.Decimal(18, 2)
  status       InstallmentStatus @default(UPCOMING)
  paidAt       DateTime?

  loan Loan @relation(fields: [loanId], references: [id])

  @@unique([loanId, seq])
  @@index([orgId, dueDate, status])
}

// ── Money movement ────────────────────────────────────────────────────────────

enum DisbursementState {
  PENDING_MAKER
  PENDING_CHECKER
  SENDING
  SENT
  CONFIRMED
  FAILED
  MANUAL_CONFIRMED // fallback mode: paid outside, ref recorded
}

model Disbursement {
  id        String            @id @default(uuid())
  orgId     String
  loanId    String            @unique
  amount    Decimal           @db.Decimal(18, 2)
  phone     String
  state     DisbursementState @default(PENDING_MAKER)
  makerId   String?
  checkerId String?
  b2cRef    String? // Daraja conversation/originator id
  receiptRef String? // M-Pesa receipt (or manual ref)
  // TO_THIRD_PARTY: who actually gets paid (frozen from the application at
  // booking). B2C to the borrower's phone is REFUSED when these are set.
  payeeName    String?
  payeePaybill String?
  payeeAccount String?
  raw       Json?
  failReason String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  loan Loan @relation(fields: [loanId], references: [id])

  @@index([orgId, state])
}

enum PaymentState {
  INITIATED
  PENDING
  SUCCESS
  FAILED
  TIMEOUT
}

/// STK push attempts (collections).
/// WHAT a payment request is FOR. The purpose decides where the money goes when it
/// lands, so it is recorded when the request is MADE, not guessed at afterwards from
/// the amount. (Guessing from the amount is how a KES 200 processing fee gets
/// allocated to a KES 200 installment.)
enum PaymentPurpose {
  /// A fee from the Charge catalogue (registration, processing, …).
  CHARGE
  /// Money against a loan — allocated to the oldest open installment.
  INSTALLMENT
  /// An officer typed an amount. Still allocated to the loan if one is named.
  CUSTOM
}

/// WHOSE money this is once it settles.
///
/// The lender's interest and principal are the LENDER's — they land in the lender's
/// own paybill. BirgenAI's fees are OURS and land in the platform till. A single STK
/// button that cannot tell these apart is a button that quietly pays the wrong party,
/// and reconciling it afterwards is guesswork.
enum ChargeBeneficiary {
  LENDER
  PLATFORM
}

/// ─────────────────────────────────────────────────────────────────────────────
/// WHAT RIRI REMEMBERS ABOUT A MEMBER OF STAFF.
///
/// The point is continuity: "the five WATCH-band loans I flagged last week — two are
/// now current, chase the other three." An assistant that forgets every Monday is a
/// search box with a personality.
///
/// Rules this table is built around:
///   • It is HERS, about THEM. One row = one thing Riri concluded about this officer's
///     work. It is not a chat transcript (RiriQueryLog already keeps those) — replaying
///     a month of chat to remember one recommendation is neither cheap nor accurate.
///   • It is org-scoped and staff-scoped. A manager does not inherit an officer's
///     memories, and a lender never sees another lender's.
///   • It holds NO CUSTOMER PII. `subjectId` points at a borrower; the body must refer
///     to them by that id or first name, never by phone/ID number — this row outlives
///     an erasure request, and a memory is not a lawful reason to keep someone's
///     identifiers (see lib/compliance/retention.ts).
///   • Recommendations go stale. `expiresAt` lets advice die of old age rather than
///     Riri nagging in November about an October arrears run.
/// ─────────────────────────────────────────────────────────────────────────────
model RiriMemory {
  id      String @id @default(uuid())
  orgId   String
  /// Whose memory this is. Riri knows each person separately.
  ///
  /// A PLAIN COLUMN, not an FK — same convention as AuditLog.actorId, and for the same
  /// reason: not every actor is a StaffUser. A platform admin acting as a lender signs
  /// in as `platform:<adminId>`, and an FK to StaffUser would throw on every write for
  /// the one person most likely to be demonstrating the product.
  staffId String

  /// recommendation — advice she gave, so she can follow it up
  /// pattern        — something she noticed about how they work
  /// preference     — how they like to be helped (language, brevity, detail)
  /// summary        — a rolling rollup, so old turns can be forgotten cheaply
  kind String

  /// The memory itself, in her words. No customer identifiers.
  body String

  /// The borrower it concerns, when it concerns one.
  subjectId String?

  /// Advice has a shelf life. Null = it does not expire (a preference).
  expiresAt DateTime?

  createdAt DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, staffId, createdAt])
}

enum ChargeTrigger {
  /// Offered the moment a borrower is registered.
  ON_REGISTRATION
  /// Offered when they apply for a loan.
  ON_APPLICATION
  /// Only ever raised by a human, from wherever they are.
  MANUAL
}

/// How a fee reaches us — ServiceSuite's ProductFeesTypes, kept verbatim because a
/// lender's fee sheet is written in this vocabulary.
enum ChargeApplyAt {
  /// The customer pays it before the money is released. This is the only one that
  /// blocks a loan, and the only one the upfront-charge gate looks at.
  BEFORE_DISBURSEMENT
  /// Netted off the principal at disbursement — they borrow 5,000 and receive 4,900.
  DEDUCT_FROM_PRINCIPAL
  /// Spread across the repayment schedule and collected with the installments.
  ON_INSTALLMENTS
}

/// EVERY LIMIT INCREASE, AND WHY.
///
/// A graduation is the system giving a customer more money on the strength of their
/// record. Two people will one day ask about it: the customer ("why did my limit go
/// up — and why did his, not mine?") and the lender ("is this engine sane?"). Neither
/// can be answered from a Borrower row that only holds the CURRENT limit.
///
/// So every increase writes the whole reasoning down: the two scores it was built
/// from, the band they landed in, the principal they had proved twice, and the
/// before/after. It is also the audit trail for the day a lender decides the engine
/// was too generous and wants to see exactly who it moved.
model GraduationEvent {
  id         String @id @default(uuid())
  orgId      String
  borrowerId String

  previousLimit Decimal @db.Decimal(18, 2)
  newLimit      Decimal @db.Decimal(18, 2)
  increase      Decimal @db.Decimal(18, 2)

  /// The behavioural score (0–100) and the band it fell in.
  riskScore Float
  riskBand  String
  /// The two halves, kept separately — "they always pay, but always late" is a
  /// completely different customer from "they pay on time but rarely in full", and a
  /// blended score cannot tell you which one you graduated.
  repaymentHistoryScore Float
  daysInArrearsScore    Float

  graduationPercent Float
  clearedLoans      Int
  /// The principal they cleared twice — what actually earned the increase.
  provenPrincipal   Decimal @db.Decimal(18, 2)
  /// True when the KES 5,000 ceiling, not the percentage, decided the increase.
  cappedByCeiling   Boolean @default(false)

  /// "cron" or a StaffUser.id — a limit can be moved by the engine or by a human.
  decidedBy String?
  createdAt DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, borrowerId, createdAt])
  @@index([orgId, createdAt])
}

/// THE CHARGE CATALOGUE — a lender's own fees, defined by the lender.
///
/// Deliberately DATA, not code (unlike the retention policy and the metric catalogue).
/// A registration fee is not a legal position or a shared definition; it is a price,
/// it differs per lender, and it changes when a lender decides it changes. Techcrast
/// charges KES 100 to register and KES 200 to process a loan; the next lender will
/// charge something else, and must not need a deploy to say so.
model Charge {
  id    String @id @default(uuid())
  orgId String

  name String /// "Registration fee"
  /// Short, stable, used as the M-Pesa AccountReference. Uppercase, no spaces.
  code String
  description String?

  /// A flat amount, or a percentage of the loan principal when `percentOf` is set.
  amount    Decimal  @db.Decimal(18, 2)
  isPercent Boolean  @default(false)

  /// Floor and ceiling for a PERCENTAGE fee (ServiceSuite ProductFees.Min/MaxValue).
  /// Micromart's school-fee product charges 5% but never less than 1,000 nor more
  /// than 2,500. Ignored for flat fees, where the amount is already the answer.
  minValue Decimal? @db.Decimal(18, 2)
  maxValue Decimal? @db.Decimal(18, 2)

  /// The principal band this price applies to (ServiceSuite ProductFees.Min/MaxPrincipal).
  /// A product may price the same fee differently at different loan sizes, so a band —
  /// not the product alone — is what selects a row. Null = any principal.
  minPrincipal Decimal? @db.Decimal(18, 2)
  maxPrincipal Decimal? @db.Decimal(18, 2)

  trigger     ChargeTrigger     @default(MANUAL)
  beneficiary ChargeBeneficiary @default(LENDER)
  /// HOW the fee is collected — orthogonal to `trigger`, which is WHEN it is offered.
  /// Mirrors ServiceSuite's ProductFeesTypes. Only BEFORE_DISBURSEMENT gates a loan:
  /// the other two are taken out of money that is already moving.
  applyAt     ChargeApplyAt     @default(BEFORE_DISBURSEMENT)

  /// Scope it to one product, or leave null for every product.
  productId String?

  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Bridged link — the ServiceSuite ProductFees row this was mirrored from.
  serviceSuiteFeeId Int?

  org      Org             @relation(fields: [orgId], references: [id])
  payments PaymentIntent[]

  @@unique([orgId, code])
  @@index([orgId, isActive])
}

/// A borrower's SAVINGS wallet with this lender. One per borrower, created lazily the
/// first time money arrives that isn't owed on a loan. The rule the product enforces:
/// a deposit lands against an OUTSTANDING LOAN BALANCE first; only what remains — or
/// everything, when the borrower carries no balance — is credited here. `balance` is a
/// running mirror of the transaction ledger, updated in the same transaction as each
/// SavingsTransaction so the two can never disagree.
model SavingsAccount {
  id         String   @id @default(uuid())
  orgId      String
  borrowerId String   @unique
  balance    Decimal  @default(0) @db.Decimal(18, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  org      Org                  @relation(fields: [orgId], references: [id])
  borrower Borrower             @relation(fields: [borrowerId], references: [id])
  entries  SavingsTransaction[]

  @@index([orgId])
}

enum SavingsDirection {
  CREDIT // money in — a deposit not owed on a loan, or a reversal
  DEBIT // money out — a withdrawal, or a sweep onto a new loan's charges
}

/// ONE MOVEMENT on a savings account — the ledger the customer statement reads. Never
/// updated once written; a correction is a new, opposite row. `balanceAfter` freezes the
/// running total at the moment of the entry so the statement is reproducible.
model SavingsTransaction {
  id         String           @id @default(uuid())
  orgId      String
  accountId  String
  borrowerId String
  direction  SavingsDirection
  amount     Decimal          @db.Decimal(18, 2)
  balanceAfter Decimal        @db.Decimal(18, 2)
  /// deposit | withdrawal | loan_offset_remainder | charge_sweep | adjustment
  source     String
  /// The M-Pesa receipt or PaymentIntent id that brought the money, when there was one.
  ref        String?
  note       String?
  createdById String? // staff actor on manual entries; null for automated
  createdAt  DateTime         @default(now())

  org     Org            @relation(fields: [orgId], references: [id])
  account SavingsAccount @relation(fields: [accountId], references: [id])

  @@index([orgId, borrowerId, createdAt])
  @@index([accountId])
}

/// ONE PAYMENT REQUEST. Every STK push in the product is one of these rows.
///
/// This used to be a repayment-only record (loanId + phone + amount). It is now the
/// single spine every payment travels down — a registration fee at the counter, a
/// processing fee on an application, an installment a collections agent prompts for
/// over the phone, a custom amount an officer types. The surfaces differ; the record,
/// the reconciliation and the audit trail do not.
///
/// THE AMOUNT IS NEVER TAKEN FROM THE CLIENT for a charge — it is read from the Charge
/// row server-side. A price that a browser can set is not a price.
model PaymentIntent {
  id                String       @id @default(uuid())
  orgId             String
  loanId            String?
  phone             String
  amount            Decimal      @db.Decimal(18, 2)
  checkoutRequestId String?      @unique
  merchantRequestId String?
  state             PaymentState @default(INITIATED)
  resultCode        String?
  resultDesc        String?
  mpesaReceipt      String?
  raw               Json?

  /// What it is for, who it is for, and who asked — the three things that let a
  /// receipt land in the right place without anybody having to work it out later.
  purpose     PaymentPurpose    @default(INSTALLMENT)
  chargeId    String?
  borrowerId  String?
  beneficiary ChargeBeneficiary @default(LENDER)
  /// The M-Pesa AccountReference actually sent. Also how an unprompted C2B payment
  /// with the same reference finds its way home.
  reference   String?
  /// Which surface it was raised from: c360 | collections | counter | field | portal | funnel.
  channel     String?
  /// StaffUser.id of whoever pressed the button. Null when the customer paid themselves.
  requestedById String?
  /// Set once the money has been applied (installment allocated, fee recorded), so a
  /// duplicate callback cannot bank the same shilling twice.
  settledAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  charge Charge? @relation(fields: [chargeId], references: [id])

  @@index([orgId, state])
  @@index([orgId, loanId])
  @@index([orgId, borrowerId])
  @@index([orgId, purpose, state])
}

/// Paybill C2B confirmations (webhooks) — allocation to schedule is a job.
model C2BReceipt {
  id              String   @id @default(uuid())
  orgId           String
  transId         String
  amount          Decimal  @db.Decimal(18, 2)
  phone           String?
  billRef         String? // account number the payer typed
  allocatedLoanId String?
  allocatedAt     DateTime?
  raw             Json?
  createdAt       DateTime @default(now())

  @@unique([orgId, transId])
  @@index([orgId, allocatedLoanId])
}

// ── Collections — the workflow layer for the humans who chase arrears ─────────
// The QUEUE is derived live from the book (loans with overdue installments);
// what persists is what a human did about it: calls logged, promises taken,
// tickets opened. ServiceSuite parity (Collections/PTPs) done native.

enum PtpStatus {
  PENDING // promise taken, due date not yet passed
  KEPT // paid in full (allocated receipts since the promise ≥ the amount)
  PARTIAL // some money came, not all of it
  BROKEN // due date passed, nothing came
  CANCELLED // superseded by a newer promise, or withdrawn with a note
}

/// A borrower's promise to pay an amount by a date — taken on a call, resolved
/// against REAL money (allocated receipts), never by a checkbox alone.
model PromiseToPay {
  id         String    @id @default(uuid())
  orgId      String
  loanId     String
  borrowerId String
  amount     Decimal   @db.Decimal(18, 2)
  dueDate    DateTime
  status     PtpStatus @default(PENDING)
  note       String?
  /// Receipts allocated to the loan from creation until resolution.
  paidAmount Decimal   @default(0) @db.Decimal(18, 2)
  createdBy  String // StaffUser.id
  resolvedAt DateTime?
  createdAt  DateTime  @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, status, dueDate])
  @@index([orgId, loanId])
}

enum CallOutcome {
  REACHED // spoke to the borrower, no promise made
  PROMISE_TO_PAY // spoke to them and took a promise (links a PromiseToPay)
  CLAIMS_PAID // borrower says they already paid — check reconciliation
  NO_ANSWER
  PHONE_OFF
  WRONG_NUMBER
  CALLBACK_LATER
  DISPUTED // borrower disputes the debt — open a ticket
}

/// One phone conversation (or attempt) about an overdue loan.
model CollectionCall {
  id         String      @id @default(uuid())
  orgId      String
  loanId     String
  borrowerId String
  outcome    CallOutcome
  note       String?
  ptpId      String? // set when the outcome was PROMISE_TO_PAY
  createdBy  String // StaffUser.id
  createdAt  DateTime    @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, loanId, createdAt])
  @@index([orgId, createdAt])
}

enum TicketKind {
  DISPUTE // "that's not my loan / I paid already"
  HARDSHIP // job loss, illness — candidates for restructuring
  FRAUD // identity theft, agent collusion
  COMPLAINT // conduct, harassment, wrong deductions
  LEGAL // demand letters, court, auctioneers
  OTHER
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED // resolved + reviewed, nothing more to do
}

/// A collections case that outlives a phone call — disputes, hardship,
/// escalations. Resolution demands a note: the row may be the only record of
/// why a lender stopped (or kept) chasing a debt.
model CollectionTicket {
  id           String       @id @default(uuid())
  orgId        String
  borrowerId   String
  loanId       String?
  kind         TicketKind
  status       TicketStatus @default(OPEN)
  title        String
  detail       String?
  assignedToId String? // StaffUser.id
  resolution   String? // mandatory when leaving OPEN/IN_PROGRESS
  createdBy    String // StaffUser.id
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, status, updatedAt])
  @@index([orgId, borrowerId])
}

enum FloatEntryKind {
  TOPUP
  DISBURSE
  REVERSAL
  ADJUSTMENT
}

model FloatLedger {
  id           String         @id @default(uuid())
  orgId        String
  kind         FloatEntryKind
  amount       Decimal        @db.Decimal(18, 2) // signed
  balanceAfter Decimal        @db.Decimal(18, 2)
  ref          String?
  note         String?
  createdBy    String?
  createdAt    DateTime       @default(now())

  @@index([orgId, createdAt])
}

enum ReconStatus {
  OPEN // needs a human
  RESOLVED // fixed (by Finance, or self-healed when the condition cleared)
  IGNORED // Finance looked and decided it is fine; stays quiet even if re-detected
}

enum ReconSeverity {
  HIGH // money moved (or claims to have moved) and the book disagrees
  MEDIUM // amounts or states inconsistent; explainable, but must be explained
  LOW // hygiene
}

/// One mismatch between the money and the book.
///
/// Written two ways, deliberately: the payment webhooks raise one at the MOMENT
/// an allocation fails (the evidence is freshest there), and the nightly sweep
/// re-derives every check from scratch — so a missed event, a crashed webhook or
/// a manual DB edit still surfaces within a day. `@@unique([orgId, kind, reference])`
/// is what lets both writers coexist: the same fact upserts into the same row,
/// re-detection bumps `lastSeenAt`, and a condition that stops reproducing is
/// closed as self-healed rather than lingering as a stale alarm.
model ReconciliationException {
  id        String        @id @default(uuid())
  orgId     String
  kind      String // C2B_UNALLOCATED | STK_SUCCESS_UNAPPLIED | DISB_STUCK | DISB_LOAN_STATE_MISMATCH | DISB_AMOUNT_MISMATCH | DUP_RECEIPT | FLOAT_DRIFT
  /// The row this points at (receipt/intent/disbursement/loan id, or "float").
  reference String
  severity  ReconSeverity
  amountKes Decimal?      @db.Decimal(18, 2)
  message   String
  meta      Json?

  status     ReconStatus @default(OPEN)
  detectedAt DateTime    @default(now())
  lastSeenAt DateTime    @default(now())
  resolvedAt DateTime?
  resolvedBy String?
  resolution String? // Finance's note, or "self-healed"

  org Org @relation(fields: [orgId], references: [id])

  @@unique([orgId, kind, reference])
  @@index([orgId, status, severity])
}

// ── Comms ────────────────────────────────────────────────────────────────────

enum SmsState {
  QUEUED
  SENT
  DELIVERED
  FAILED
}

model SmsMessage {
  id          String   @id @default(uuid())
  orgId       String
  phone       String
  message     String
  templateKey String? // otp | app_received | approved | disbursed | payment | reminder | arrears
  state       SmsState @default(QUEUED)
  provider    String?
  providerRef String?
  cost        Decimal? @db.Decimal(9, 4)
  sentAt      DateTime?
  createdAt   DateTime @default(now())

  @@index([orgId, state, createdAt])
}

model SmsTemplate {
  id        String   @id @default(uuid())
  orgId     String
  key       String // event key
  title     String
  body      String // with {placeholders}
  active    Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@unique([orgId, key])
}

enum CampaignStatus {
  DRAFT
  SENDING
  SENT // every recipient row created (delivery states live on SmsMessage)
  FAILED
}

/// A one-off SMS blast to a borrower segment (ServiceSuite "SMS Campaign"
/// parity). The campaign is the intent + audience + counts; each actual message
/// is an SmsMessage row tagged `campaign:<id>`, so delivery/queueing/billing
/// stay on the same rails as every other SMS.
model SmsCampaign {
  id         String         @id @default(uuid())
  orgId      String
  name       String
  message    String // free text; {name} substitutes the borrower's first name
  audience   String // ALL | ACTIVE_LOANS | ARREARS | CLEARED | BROKEN_PTP
  recipients Int            @default(0) // enumerated at send time
  queued     Int            @default(0) // rows created (sent or waiting for credit)
  status     CampaignStatus @default(DRAFT)
  createdBy  String // StaffUser.id
  sentAt     DateTime?
  createdAt  DateTime       @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
}

/// Outbound email log (ServiceSuite EmailMessage parity). Every transactional
/// send — invite credentials, sign-in codes, approvals — leaves a row, so
/// "did the system email them?" has an answer that isn't a shrug.
model EmailMessage {
  id        String   @id @default(uuid())
  orgId     String
  to        String
  subject   String
  template  String? // staff_invite | login_otp | approval_otp | reset_code | welcome | raw
  state     String // SENT | FAILED
  error     String?
  createdAt DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
}

enum SmsTopUpSource {
  HUB // paid through the BirgenAI wallet; hubReference is the Hub's record
  PLATFORM_GRANT // granted from the platform board (sales, goodwill, demos)
}

/// Prepaid SMS credits, spent only by messages that ride the PLATFORM's provider.
///
/// SMS is the one metered kind whose third-party cost cannot be feature-gated
/// up front — a borrower's signing code has to go out — so it is prepaid rather
/// than invoiced in arrears: the plan's monthly allowance is spent first, then
/// this balance. At zero, CRITICAL messages (codes, consent links) overdraw into
/// the negative — a billing lapse must never lock a borrower out of signing —
/// and the next top-up settles the overdraft. Discretionary messages queue until
/// credit arrives. An org sending through its OWN vault provider never touches
/// this wallet: those messages cost us nothing, so we charge nothing.
model SmsWallet {
  orgId     String   @id
  balance   Int      @default(0) // whole messages; negative = critical overdraft
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])
}

/// One purchase (or grant) of SMS credits. The MONEY side lives in the Hub
/// wallet — `hubReference` is the Hub's settlement record, and its uniqueness is
/// what makes read-back crediting idempotent: syncing twice cannot credit twice.
model SmsTopUp {
  id           String         @id @default(uuid())
  orgId        String
  units        Int
  amountKes    Decimal        @db.Decimal(18, 2)
  source       SmsTopUpSource
  hubReference String?        @unique
  note         String?
  createdBy    String? // platform actor on grants; null for wallet purchases
  createdAt    DateTime       @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
}

// ── Intelligence & metering ──────────────────────────────────────────────────

model ScoreSnapshot {
  id            String   @id @default(uuid())
  orgId         String
  borrowerId    String?
  applicationId String?
  serviceSuiteBorrowerId Int? // bridged-mode borrower link (outcome backfill)
  serviceSuiteLoanId     String?
  modelKind     String // thin-file | origination-v2 | pooled-v3 | behavioral-v1 | fused
  modelVersion  String
  score         Int?
  pd            Decimal? @db.Decimal(6, 5)
  riskBand      String?
  features      Json?
  reasons       Json?
  loanContextAmount Decimal? @db.Decimal(18, 2)
  // Outcome label (y) — backfilled like LoanApplication
  outcome           String    @default("PENDING")
  outcomeObservedAt DateTime?
  capturedBy    String? // apply | batch | hook
  createdAt     DateTime @default(now())

  @@index([orgId, borrowerId])
  @@index([orgId, modelKind, createdAt])
  @@index([orgId, outcome])
}

/// One batch sweep of an org's live book by the early-warning engine, frozen in
/// time — so portfolio risk becomes a trend a Credit Manager can watch, not a
/// number that overwrites itself. Each run records the tiles, who was on the
/// watchlist (compact rows, for movement between runs), which policy scored it,
/// and the model-drift report computed against realised ScoreSnapshot outcomes.
model PortfolioRun {
  id      String   @id @default(uuid())
  orgId   String
  ranAt   DateTime @default(now())
  trigger String // cron | manual | seed
  /// The scoring policy in force: "default" or "custom v<n>" — a risk trend
  /// where the policy silently changed mid-line is a lie, so every point says.
  policy  String

  activeLoans   Int
  olb           Decimal @db.Decimal(18, 2)
  atRiskValue   Decimal @db.Decimal(18, 2)
  projectedLoss Decimal @db.Decimal(18, 2)
  watchlist     Int
  high          Int
  elevated      Int

  // Movement vs the previous run (borrowers, not loans).
  entered   Int @default(0)
  left      Int @default(0)
  escalated Int @default(0)
  improved  Int @default(0)

  /// Compact watchlist snapshot [{b,l,n,s,band,dpd,bal}] — enough to diff runs
  /// and name who moved, never the full risk row (that is recomputed live).
  rows  Json
  /// DriftReport (lib/intelligence/drift.ts) as of this run; null when the org
  /// has no scoring history to measure.
  drift Json?

  @@index([orgId, ranAt])
}

model GeoPin {
  id            String   @id @default(uuid())
  orgId         String
  borrowerId    String?
  applicationId String?
  label         String
  lat           Float
  lng           Float
  accuracyMeters Int?
  locationType  String? // business | home
  address       String?
  phone         String?
  source        String   @default("self-onboard") // self-onboard | ro-visit
  note          String?
  capturedBy    String?
  createdAt     DateTime @default(now())

  @@index([orgId])
}

/// The semantic layer's per-org overlay.
///
/// The metric CATALOGUE ITSELF IS CODE (src/lib/riri/catalog.ts) — same reasoning
/// as the billing price book: what a metric MEANS ("PAR 30 is the balance of every
/// active loan with an installment more than 30 days overdue, over the outstanding
/// book") changes rarely, deliberately, and under review. It is not CRUD.
///
/// What belongs to the lender is how they SPEAK about it and what they hold
/// themselves to: the words their staff actually use ("delinquency", "my book"),
/// the number they target, and whether Riri may quote it at all. That is this row.
/// A metricId absent from the code catalogue cannot be created here.
model MetricDefinition {
  id       String @id @default(uuid())
  orgId    String
  /// Catalogue key — validated against MetricSpec.id at write time.
  metricId String

  /// What this lender calls it. Null = the catalogue's own label.
  label String?
  /// Extra words their staff use for it. Riri routes on these too.
  synonyms String[] @default([])
  /// A metric switched off is never quoted, routed to, or offered as a suggestion.
  enabled Boolean @default(true)

  /// The number they hold themselves to, in the metric's own unit (PAR 30 ≤ 5).
  target Float?
  /// Which side of the target is good: "below" | "above".
  targetDirection String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])

  @@unique([orgId, metricId])
  @@index([orgId])
}

/// Every question put to Riri, with the SQL that answered it.
///
/// The blueprint's rule for the analytics tier is "SQL always shown"; this is the
/// record of what was shown, kept for the three parties who will one day ask:
/// the lender (did she read my book correctly?), us (what do lenders actually ask,
/// and which questions does the catalogue miss?), and a regulator (on what basis
/// was this number reported?). Refusals are logged too — a question the guard
/// turned away is exactly the kind we want to see.
model RiriQueryLog {
  id      String  @id @default(uuid())
  orgId   String
  staffId String?

  model    String // analyst | copilot | max
  question String

  /// How it was answered:
  ///   catalog   — a governed metric, compiled to SQL by us
  ///   llm       — SQL proposed by a model, then put through the same guard
  ///   engine    — a model, not SQL (early-warning); numbers still real
  ///   narrative — no data read (Copilot/Max, help)
  ///   refused   — the guard said no; `error` says why
  route    String
  metricId String?

  /// The exact statement that ran, as the lender was shown it. Null when none did.
  sql  String?
  rows Int?
  ms   Int?
  ok   Boolean @default(true)
  /// The guard's reason, or the database's error, verbatim. Never paraphrased.
  error String?

  createdAt DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
  @@index([orgId, route])
}

/// Usage metering for Intelligence Suite billing (per-score, per-statement,
/// per-document, per-CRB-check, per-verification, Riri seats, SMS).
model UsageEvent {
  id        String   @id @default(uuid())
  orgId     String
  kind      String // score | statement | document | crb | kyc | riri_query | sms
  qty       Int      @default(1)
  unitCost  Decimal? @db.Decimal(9, 4)
  meta      Json?
  createdAt DateTime @default(now())

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, kind, createdAt])
}

enum InvoiceStatus {
  ISSUED // frozen and owed
  PAID // settled through the Hub wallet
  VOID // cancelled; kept, never deleted
}

/// A month, closed and frozen.
///
/// Once issued, an invoice never recomputes. Its lines carry the quantity and the
/// price AS CHARGED — read from each UsageEvent's own `unitCost`, not from today's
/// catalogue — so re-pricing CRB tomorrow cannot rewrite what a lender owed last
/// month. That is the whole reason `unitCost` is stamped onto every event.
///
/// One invoice per org per period; the unique constraint is what makes the monthly
/// freeze safe to run twice.
model Invoice {
  id     String @id @default(uuid())
  orgId  String
  /// Human reference: INV-<slug>-YYYYMM.
  number String @unique

  periodStart DateTime
  periodEnd   DateTime

  plan       String // the package as it stood when the month closed
  planFeeKes Decimal @db.Decimal(18, 2)
  overageKes Decimal @db.Decimal(18, 2)
  totalKes   Decimal @db.Decimal(18, 2)
  currency   String  @default("KES")

  status   InvoiceStatus @default(ISSUED)
  issuedAt DateTime      @default(now())
  paidAt   DateTime?
  /// Hub PaymentIntent / receipt, once the wallet settles it.
  hubReference String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org   Org           @relation(fields: [orgId], references: [id])
  lines InvoiceLine[]

  @@unique([orgId, periodStart])
  @@index([orgId, status])
}

model InvoiceLine {
  id        String @id @default(uuid())
  orgId     String
  invoiceId String

  /// "subscription", or a UsageKind.
  kind  String
  label String
  /// Units billed on this line (already net of the included allowance).
  qty         Int
  /// How many of this kind the plan covered for free. Shown, never charged.
  includedQty Int @default(0)
  /// The price as charged. A month with a mid-period reprice yields two lines.
  unitCostKes Decimal @db.Decimal(9, 4)
  amountKes   Decimal @db.Decimal(18, 2)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([orgId, invoiceId])
}

/// The commercial relationship with one lender.
///
/// `Org.plan` names WHICH plan; the plan's features, included quotas and unit
/// prices live in code (src/lib/billing/plans.ts), not here — a price book is a
/// deployable, not tenant data. This row holds what is genuinely per-org: the
/// billing period, whether they are paying, and any commercial overrides a
/// salesperson negotiated on top of the catalogue.
model OrgSubscription {
  id     String             @id @default(uuid())
  orgId  String             @unique
  status SubscriptionStatus @default(TRIALING)

  trialEndsAt        DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime

  /// Grant/revoke individual features regardless of plan: { "early_warning": true }
  featureOverrides Json?
  /// Raise included monthly quotas: { "crb": 200 }
  includedOverrides Json?
  /// Override the plan's staff-seat cap. Null = use the plan's.
  seatsOverride Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])
}

/// Fixed-window request counters (src/lib/ratelimit.ts). One row per
/// bucket:subject; the window advances in place via an atomic upsert.
///
/// Deliberately has NO orgId and NO RLS policy: the limiter must run before the
/// caller's tenant is known (staff login, OTP issue on an unresolved slug), and
/// it holds no tenant data — only a coarse counter keyed by phone/IP/email.
/// It is therefore reached through `rawPrisma`, the one sanctioned use in app
/// code. Expired rows are swept by the daily arrears cron.
model RateLimit {
  key         String   @id // "<bucket>:<subject>"
  windowStart DateTime
  count       Int      @default(0)
  expiresAt   DateTime

  @@index([expiresAt])
}

// ── Compliance: the data-subject register ─────────────────────────────────────

enum ComplianceRequestKind {
  /// Kenya DPA 2019 s.26(a) — right of access. A copy of everything held.
  BORROWER_EXPORT
  /// s.40 — right to erasure. Honoured as far as the AML floor allows; see
  /// src/lib/compliance/erasure.ts.
  BORROWER_ERASURE
  /// The lender's own book, machine-readable. Offboarding, audit, portability.
  ORG_EXPORT
  /// Tenant wipe. An org admin may ASK; only a platform admin may execute.
  ORG_DELETION
}

enum ComplianceRequestStatus {
  /// Raised, awaiting a second pair of eyes (or the platform, for a tenant wipe).
  PENDING
  /// Approved, not yet executed. Destructive requests wait here.
  APPROVED
  /// Done. `result` carries what was erased and what the law made us keep.
  COMPLETED
  REJECTED
  /// Execution ran and threw. Kept, never retried silently.
  FAILED
}

/// Every data-subject request, and what we did about it.
///
/// The Data Protection Act gives a borrower rights (access, erasure) and gives the
/// ODPC the right to ask a lender how those requests were handled. This table is
/// that answer: who asked, who approved, when it ran, what was deleted, and — the
/// part that matters in a lending business — WHAT WE REFUSED TO DELETE AND WHY.
///
/// IT HOLDS NO PERSONAL DATA. An export's bytes stream to the browser and are never
/// stored; `result` carries counts and reasons, not rows. Erasing a person must not
/// leave a copy of them in the register that recorded the erasure. `subjectLabel` is
/// the one exception and is deliberately coarse (a masked phone), so the register
/// stays readable after the borrower row itself has been anonymised.
model ComplianceRequest {
  id     String                  @id @default(uuid())
  orgId  String
  kind   ComplianceRequestKind
  status ComplianceRequestStatus @default(PENDING)

  /// Borrower.id for the subject-scoped kinds. Survives anonymisation (the row
  /// stays, its PII does not), so the register can still link to the record.
  subjectId    String?
  /// A masked handle for the register's own list — "2547••••1234". Never a name.
  subjectLabel String?

  /// Mandatory. An irreversible act explains itself, in the words of whoever asked.
  reason String

  requestedById String? // StaffUser.id
  decidedById   String? // StaffUser.id — the second pair of eyes
  decidedAt     DateTime?
  completedAt   DateTime?

  /// The assessment before, and the outcome after: what was deleted, what was kept,
  /// under which retention floor. Counts and reasons only.
  result Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Org @relation(fields: [orgId], references: [id])

  @@index([orgId, status])
  @@index([orgId, createdAt])
  @@index([orgId, subjectId])
}
